        "ggl6JQwM_or_text": "<p><span style=\"font-size:16px;\">New Customers Only</span></p><p><span style=\"font-size:16px;\">Code: <strong>$10Off-LBORA</strong></span></p>",
        "ggfFmyMB8si_defaultLabel": "Copy",
