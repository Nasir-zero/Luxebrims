        "ggchduOuyVL_text": "<p><span style=\"font-size:16px;\">Over $200</span></p><p><span style=\"font-size:16px;\">Code: <strong>Easter Sale Over$200</strong></span></p>",
        "ggvJlwDb1Dm_defaultLabel": "Copy",
        "ggvJlwDb1Dm_clickedLabel": "Copy",
        "ggOtRvpx-IM_text": "Quantity",
        "ggbxEqmf6Uc_text": "<p><u>Size Guide</u></p>",
        "gg9KXz_HMtn_text": "<p><a href=\"https://shoplbora.com/pages/process-flow\" target=\"_blank\"><u>Process Flow</u></a></p>",
        "ggkbr6T7q67_label": "Add To cart",
        "ggkbr6T7q67_outOfStockLabel": "Out of stock",
