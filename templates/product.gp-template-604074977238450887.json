        "ggXMQH50O_v_text": "<p><u>Size Guide</u></p>",
        "ggwaexCKHkm_text": "<p><a href=\"https://shoplbora.com/pages/process-flow\" target=\"_blank\"><u>Process Flow</u></a></p>",
        "ggiJ5SE1Xtr_label": "Add To cart",
