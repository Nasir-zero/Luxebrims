        "gg-ggxvpNUD_text": "<p><u>Size Guide</u></p>",
        "ggjmQoCEOFC_text": "<p><a href=\"https://shoplbora.com/pages/process-flow\" target=\"_blank\"><u>Process Flow</u></a></p>",
