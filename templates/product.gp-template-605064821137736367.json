        "gg4PNAi7soe_text": "<p><u>Size Guide</u></p>",
        "ggAz8sE8mMK_text": "<p><a href=\"https://shoplbora.com/pages/process-flow\" target=\"_blank\"><u>Process Flow</u></a></p>",
        "ggGmf16r7qA_label": "Add To cart",
        "ggGmf16r7qA_outOfStockLabel": "Out of stock",
