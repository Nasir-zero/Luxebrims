        "ggh7bZ0Ahjx_text": "<p><u>Size Guide</u></p>",
        "gg7Mq_cxXKQ_text": "<p><a href=\"https://shoplbora.com/pages/process-flow\" target=\"_blank\"><u>Process Flow</u></a></p>",
        "ggsVT0RmHK5_label": "Add To cart",
        "ggsVT0RmHK5_outOfStockLabel": "Out of stock",
