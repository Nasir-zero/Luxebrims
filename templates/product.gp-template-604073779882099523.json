        "ggAmau-K2Vf_text": "<p><u>Size Guide</u></p>",
        "gg4Y4Qs68N0_text": "<p><a href=\"https://shoplbora.com/pages/process-flow\" target=\"_blank\"><u>Process Flow</u></a></p>",
        "ggYyhMyy1k5_label": "Add To cart",
