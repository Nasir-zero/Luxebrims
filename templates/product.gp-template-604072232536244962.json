        "gg_UrfFT-vK_text": "<p><span style=\"font-size:16px;\">Over $200</span></p><p><span style=\"font-size:16px;\">Code: <strong>Easter Sale Over$200</strong></span></p>",
        "gg09_-pjMHU_defaultLabel": "Copy",
        "gg09_-pjMHU_clickedLabel": "Copy",
        "ggm0hC2a59f_text": "Quantity",
        "ggM3a8aHiru_text": "<p><u>Size Guide</u></p>",
        "ggM3dJnCId3_text": "<p><a href=\"https://shoplbora.com/pages/process-flow\" target=\"_blank\"><u>Process Flow</u></a></p>",
        "ggUK2hIvqMO_label": "Add To cart",
        "ggUK2hIvqMO_outOfStockLabel": "Out of stock",
